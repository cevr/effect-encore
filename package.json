{
  "name": "effect-encore",
  "version": "0.8.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/cevr/effect-encore.git"
  },
  "files": [
    "dist",
    "v3/dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./v3": {
      "import": {
        "types": "./v3/dist/index.d.ts",
        "default": "./v3/dist/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "typecheck:v3": "tsgo --noEmit -p v3/tsconfig.json",
    "lint": "concurrently -n ox,effect -c yellow,blue \"oxlint\" \"bun run lint:effect\"",
    "lint:ox": "oxlint",
    "lint:effect": "concurrently \"bun run lint:effect:src\" \"bun run lint:effect:test\"",
    "lint:effect:src": "effect-language-service diagnostics --project tsconfig.src.json --lspconfig \"$(cat .effect-lsp.json)\"",
    "lint:effect:test": "effect-language-service diagnostics --project tsconfig.test.json --lspconfig \"$(cat .effect-lsp.test.json)\"",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test",
    "test:v3": "bun test --tsconfig-override=v3/tsconfig.json v3/test/",
    "test:watch": "bun test --watch",
    "gate": "concurrently -n type,type:v3,lint,fmt,build,test -c blue,blue,yellow,magenta,cyan,green \"bun run typecheck\" \"bun run typecheck:v3\" \"bun run lint\" \"bun run fmt\" \"bun run build\" \"bun run test\"",
    "build": "concurrently \"tsdown\" \"tsdown --config v3/tsdown.config.ts\"",
    "release": "bun run build && changeset publish",
    "version": "changeset version",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@effect/cluster": "^0.56.2",
    "@effect/language-service": "^0.85.1",
    "@effect/rpc": "^0.73.0",
    "@effect/workflow": "^0.18.0",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260410.1",
    "concurrently": "^9.2.1",
    "effect": "4.0.0-beta.46",
    "effect-bun-test": "^0.3.0",
    "effect-v3": "npm:effect@^3.21.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@effect/cluster": "*",
    "@effect/rpc": "*",
    "@effect/workflow": "*",
    "effect": ">=4.0.0-beta.46"
  },
  "peerDependenciesMeta": {
    "@effect/cluster": {
      "optional": true
    },
    "@effect/rpc": {
      "optional": true
    },
    "@effect/workflow": {
      "optional": true
    }
  }
}
